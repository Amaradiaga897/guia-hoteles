{
  "name": "guia-hoteles",
  "version": "1.0.0",
  "description": "Nuestro primer proyecto de Nodejs",
  "keywords": [
    "Nuestro",
    "primer",
    "proyecto",
    "de",
    "NodeJS"
  ],
  "homepage": "https://github.com/Amaradiaga897/guia-hoteles#readme",
  "bugs": {
    "url": "https://github.com/Amaradiaga897/guia-hoteles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amaradiaga897/guia-hoteles.git"
  },
  "license": "ISC",
  "author": "Andres Maradiaga",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "dev": "lite-server",
    "start": "concurrently \"npm run watch-scss\" \"npm run dev\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "scss": "sass css/:css/",
    "watch-scss": "onchange \"css/*.scss\" -- npm run scss",
    "clean-css": "rimraf css/*.css",
    "clean": "rimraf dist",
    "imagemin": "imagemin img/* --out-dir=dist/img",
    "grunt": "grunt",
    "usemin": "usemin index.html -d dist --htmlmin -o dist/index.html && usemin index.html -d dist --htmlmin -o dist/about.html && usemin index.html -d dist --htmlmin -o dist/contacto.html && usemin index.html -d dist --htmlmin -o dist/precios.html",
    "build": "npm run clean &&npm run scss && npm run imagemin && npm run usemin"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "copyfiles": "^2.4.1",
    "cssmin": "^0.4.3",
    "del": "^8.0.1",
    "grunt": "^1.6.1",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-concat": "^2.1.0",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-contrib-cssmin": "^5.0.0",
    "grunt-contrib-imagemin": "^4.0.0",
    "grunt-contrib-sass": "^2.0.0",
    "grunt-contrib-uglify": "^5.2.2",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-filerev": "^2.3.1",
    "grunt-usemin": "^3.1.1",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-flatmap": "^1.0.2",
    "gulp-htmlmin": "^5.0.1",
    "gulp-imagemin": "^7.1.0",
    "gulp-rev": "^12.0.0",
    "gulp-sass": "^6.0.1",
    "gulp-uglify": "^3.0.2",
    "gulp-usemin": "^0.3.30",
    "htmlmin": "^0.0.7",
    "install": "^0.13.0",
    "jit-grunt": "^0.10.0",
    "lite-server": "^2.6.1",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.3",
    "time-grunt": "^1.4.0",
    "uglifyjs": "^2.4.11",
    "usemin-cli": "^0.6.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "jquery": "^4.0.0",
    "open-iconic": "^1.1.1",
    "popper.js": "^1.16.1",
    "sass": "^1.98.0"
  }
}
