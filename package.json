{
  "name": "guia-hoteles",
  "version": "1.0.0",
  "description": "Nuestro primer proyecto de Nodejs",
  "keywords": [
    "Nuestro",
    "primer",
    "proyecto",
    "de",
    "NodeJS"
  ],
  "homepage": "https://github.com/Amaradiaga897/guia-hoteles#readme",
  "bugs": {
    "url": "https://github.com/Amaradiaga897/guia-hoteles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amaradiaga897/guia-hoteles.git"
  },
  "license": "ISC",
  "author": "Andres Maradiaga",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "dev": "lite-server",
    "start": "concurrently \"npm run watch-scss\" \"npm run dev\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "scss": "sass css/:css/",
    "watch-scss": "onchange \"css/*.scss\" -- npm run scss",
    "clean-css": "rimraf css/*.css",
    "clean": "rimraf dist",
    "imagemin": "imagemin img/* --out-dir=dist/img",
    "usemin": "usemin index.html -d dist --htmlmin -o dist/index.html && usemin index.html -d dist --htmlmin -o dist/about.html && usemin index.html -d dist --htmlmin -o dist/contacto.html && usemin index.html -d dist --htmlmin -o dist/precios.html", 
    "build": "npm run clean &&npm run scss && npm run imagemin && npm run usemin"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "cssmin": "^0.4.3",
    "htmlmin": "^0.0.7",
    "lite-server": "^2.6.1",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.3",
    "uglifyjs": "^2.4.11",
    "usemin-cli": "^0.6.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "jquery": "^4.0.0",
    "open-iconic": "^1.1.1",
    "popper.js": "^1.16.1",
    "sass": "^1.98.0"
  }
}
